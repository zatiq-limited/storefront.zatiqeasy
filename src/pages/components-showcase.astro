---
/**
 * Component Showcase Page
 * Displays all migrated components for testing and preview
 */
import '../styles/global.css';

// Import all components directly for showcase
import AnnouncementBar1 from '../components/AnnouncementBar/AnnouncementBar1.astro';
import AnnouncementBar2 from '../components/AnnouncementBar/AnnouncementBar2.astro';
import AnnouncementBar3 from '../components/AnnouncementBar/AnnouncementBar3.astro';

import Navbar1 from '../components/Navbar/Navbar1.astro';
import Navbar2 from '../components/Navbar/Navbar2.astro';
import Navbar3 from '@/components/Navbar/Navbar3.astro';
import Navbar4 from '@/components/Navbar/Navbar4.astro';

import Hero1 from '../components/Hero/Hero1.astro';
import Hero2 from '../components/Hero/Hero2.astro';

import Category1 from '../components/Category/Category1.astro';

import ProductCards1 from '../components/ProductCards/ProductCards1.astro';

import Badges1 from '../components/Badges/Badges1.astro';

import Reviews1 from '../components/Reviews/Reviews1.astro';

import Brands1 from '../components/Brands/Brands1.astro';

import StaticBanner1 from '../components/StaticBanner/StaticBanner1.astro';
import StaticBanner2 from '../components/StaticBanner/StaticBanner2.astro';
import StaticBanner3 from '../components/StaticBanner/StaticBanner3.astro';
import StaticBanner4 from '../components/StaticBanner/StaticBanner4.astro';

import SpecialOffersSlider1 from '../components/SpecialOffersSlider/SpecialOffersSlider1.astro';
import SpecialOffersSlider2 from '../components/SpecialOffersSlider/SpecialOffersSlider2.astro';
import SpecialOffersSlider3 from '../components/SpecialOffersSlider/SpecialOffersSlider3.astro';
import SpecialOffersSlider4 from '../components/SpecialOffersSlider/SpecialOffersSlider4.astro';
import SpecialOffersSlider5 from '../components/SpecialOffersSlider/SpecialOffersSlider5.astro';

import Footers1 from '../components/Footers/Footers1.astro';
import Hero3 from '@/components/Hero/Hero3.astro';
import Hero4 from '@/components/Hero/Hero4.astro';
import Category2 from '@/components/Category/Category2.astro';
import Category3 from '@/components/Category/Category3.astro';
import Category4 from '@/components/Category/Category4.astro';
import Category5 from '@/components/Category/Category5.astro';
import Category6 from '@/components/Category/Category6.astro';
import ProductCards2 from '@/components/ProductCards/ProductCards2.astro';
import ProductCards3 from '@/components/ProductCards/ProductCards3.astro';
import ProductCards4 from '@/components/ProductCards/ProductCards4.astro';
import ProductCards5 from '@/components/ProductCards/ProductCards5.astro';
import ProductCards6 from '@/components/ProductCards/ProductCards6.astro';
import ProductCards7 from '@/components/ProductCards/ProductCards7.astro';
import ProductCards8 from '@/components/ProductCards/ProductCards8.astro';
import Badges2 from '@/components/Badges/Badges2.astro';
import Badges3 from '@/components/Badges/Badges3.astro';
import Reviews2 from '@/components/Reviews/Reviews2.astro';
import Reviews3 from '@/components/Reviews/Reviews3.astro';
import Brands2 from '@/components/Brands/Brands2.astro';
import Brands3 from '@/components/Brands/Brands3.astro';
import Footers2 from '@/components/Footers/Footers2.astro';
import PaymentStatus1 from '../components/PaymentStatus/PaymentStatus1.astro';
import PaymentStatus2 from '../components/PaymentStatus/PaymentStatus2.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Component Showcase - Zatiq Storefront</title>
</head>
<body class="bg-gray-50">
  <div class="max-w-7xl mx-auto py-12 px-4">
    <h1 class="text-4xl font-bold text-center mb-12">Component Showcase</h1>
    
    <!-- AnnouncementBars -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6 border-b pb-2">Announcement Bars (3)</h2>
      <div class="space-y-4">
        <div>
          <p class="text-sm text-gray-600 mb-2">AnnouncementBar1</p>
          <AnnouncementBar1 />
        </div>
        <div>
          <p class="text-sm text-gray-600 mb-2">AnnouncementBar2</p>
          <AnnouncementBar2 />
        </div>
        <div>
          <p class="text-sm text-gray-600 mb-2">AnnouncementBar3</p>
          <AnnouncementBar3 />
        </div>
      </div>
    </section>

    <!-- Navbars -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-6 border-b pb-2">Navigation Bars (4)</h2>
      <div class="space-y-8">
        <div>
